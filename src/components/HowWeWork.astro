---
import site from '../data/site.json';

const { howWeWork } = site;
---

<section class="section how-we-work" id="cum-lucram" aria-labelledby="how-we-work-title">
  <div class="container container--wide">
    <p class="section__eyebrow">Procesul nostru</p>
    <h2 class="section__title" id="how-we-work-title">{howWeWork.title}</h2>

    <ol class="how-we-work__steps">
      {howWeWork.steps.map((step, index) => (
        <li class="how-we-work__step">
          <span class="how-we-work__num" aria-hidden="true">{index + 1}</span>
          <span class="how-we-work__icon" aria-hidden="true">{step.icon}</span>
          <h3 class="how-we-work__step-title">{step.title}</h3>
          <p class="how-we-work__step-text">{step.text}</p>
        </li>
      ))}
    </ol>

    <div class="how-we-work__footer">
      <p class="how-we-work__tagline">{howWeWork.tagline}</p>
      <p class="how-we-work__closing">{howWeWork.closing}</p>
    </div>
  </div>
</section>

<style>
  .how-we-work {
    padding-top: 3rem;
    padding-bottom: 3.5rem;
  }

  .how-we-work__steps {
    list-style: none;
    margin: 0 0 2.5rem;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .how-we-work__step {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.35rem 1.15rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius) + 4px);
    box-shadow: var(--shadow-sm);
  }

  .how-we-work__num {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    opacity: 0.75;
  }

  .how-we-work__icon {
    font-size: 1.65rem;
    line-height: 1;
  }

  .how-we-work__step-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.2;
  }

  .how-we-work__step-text {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-muted);
  }

  .how-we-work__footer {
    max-width: 46rem;
    text-align: center;
    margin-inline: auto;
    padding: 1.5rem 1.25rem;
    border-radius: calc(var(--radius) + 4px);
    background: var(--color-accent-soft);
    border: 1px solid var(--color-border);
  }

  .how-we-work__tagline {
    margin: 0 0 0.65rem;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    font-weight: 500;
    color: var(--color-accent-dark);
    letter-spacing: 0.02em;
  }

  .how-we-work__closing {
    margin: 0;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--color-muted);
  }

  @media (max-width: 1000px) {
    .how-we-work__steps {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .how-we-work__steps {
      grid-template-columns: 1fr;
    }
  }
</style>
