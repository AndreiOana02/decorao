---
import site from '../data/site.json';

interface Props {
  variant?: 'light' | 'dark' | 'icons';
}

const { variant = 'dark' } = Astro.props;

const icons: Record<string, { viewBox: string; path: string }> = {
  facebook: {
    viewBox: '0 0 24 24',
    path: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  },
  instagram: {
    viewBox: '0 0 24 24',
    path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z',
  },
  tiktok: {
    viewBox: '0 0 24 24',
    path: 'M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z',
  },
};
---

<ul class:list={['social', `social--${variant}`]}>
  {site.social.map((item) => (
    <li>
      <a
        href={item.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={item.label}
      >
        {variant === 'icons' ? (
          <svg
            class="social__icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox={icons[item.id]?.viewBox ?? '0 0 24 24'}
            width="20"
            height="20"
            aria-hidden="true"
            fill="currentColor"
          >
            <path d={icons[item.id]?.path ?? ''} />
          </svg>
        ) : (
          item.label
        )}
      </a>
    </li>
  ))}
</ul>

<style>
  .social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .social a {
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    border: 1px solid currentColor;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .social--dark a {
    color: #f5f0e8;
    border-color: rgba(245, 240, 232, 0.35);
  }

  .social--dark a:hover {
    background: #f5f0e8;
    color: var(--color-text);
  }

  .social--light a {
    color: var(--color-accent-dark);
    border-color: var(--color-border);
    background: var(--color-surface);
  }

  .social--light a:hover {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .social--icons {
    gap: 0.35rem;
  }

  .social--icons a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border-radius: 50%;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .social--icons a:hover {
    color: var(--color-accent-dark);
    border-color: var(--color-accent);
    background: rgba(139, 94, 60, 0.08);
  }

  .social__icon {
    display: block;
    flex-shrink: 0;
  }
</style>
