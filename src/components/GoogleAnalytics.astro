---
import site from '../data/site.json';

const gaId =
  import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim() ||
  site.googleAnalyticsId?.trim() ||
  '';
const enabled = import.meta.env.PROD && /^G-[A-Z0-9]+$/i.test(gaId);
---

{enabled && (
  <>
    <div class="cookie-banner" id="cookie-consent" role="dialog" aria-label="Preferințe cookie">
      <p>
        Folosim cookie-uri de analiză (Google Analytics) ca să vedem câți vizitatori avem — fără nume
        sau date personale. Poți accepta sau refuza.
      </p>
      <div class="cookie-banner__actions">
        <button type="button" class="cookie-banner__btn cookie-banner__btn--ghost" id="cookie-reject">
          Refuz
        </button>
        <button type="button" class="cookie-banner__btn cookie-banner__btn--primary" id="cookie-accept">
          Accept
        </button>
      </div>
    </div>

    <script is:inline define:vars={{ gaId }}>
      (function () {
        const KEY = 'decorao_analytics';
        const banner = document.getElementById('cookie-consent');

        function loadGA() {
          if (window.__decoraoGaLoaded) return;
          window.__decoraoGaLoaded = true;
          const s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaId;
          document.head.appendChild(s);
          window.dataLayer = window.dataLayer || [];
          function gtag() {
            dataLayer.push(arguments);
          }
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', gaId, { anonymize_ip: true });
        }

        const choice = localStorage.getItem(KEY);
        if (choice === 'yes') {
          loadGA();
          banner?.remove();
        } else if (choice === 'no') {
          banner?.remove();
        }

        document.getElementById('cookie-accept')?.addEventListener('click', () => {
          localStorage.setItem(KEY, 'yes');
          loadGA();
          banner?.remove();
        });

        document.getElementById('cookie-reject')?.addEventListener('click', () => {
          localStorage.setItem(KEY, 'no');
          banner?.remove();
        });
      })();
    </script>
  </>
)}

<style>
  .cookie-banner {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 100;
    max-width: 26rem;
    margin: 0 auto;
    padding: 1rem 1.1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: calc(var(--radius) + 4px);
    box-shadow: var(--shadow-lg);
  }

  .cookie-banner p {
    margin: 0 0 0.85rem;
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--color-muted);
  }

  .cookie-banner__actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .cookie-banner__btn {
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font: inherit;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid var(--color-border);
  }

  .cookie-banner__btn--ghost {
    background: transparent;
    color: var(--color-text);
  }

  .cookie-banner__btn--primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  @media (min-width: 600px) {
    .cookie-banner {
      left: auto;
      right: 1.25rem;
      margin: 0;
    }
  }
</style>
