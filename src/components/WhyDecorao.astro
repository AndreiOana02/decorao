---
import site from '../data/site.json';

const { why } = site;
---

<section class="section why" id="de-ce" aria-label={why.title}>
  <div class="container container--wide">
    <figure class="why__showcase">
      <img
        src={why.showcaseImage}
        alt={`${why.title} — ${why.intro}`}
        width="1200"
        height="800"
        loading="lazy"
        decoding="async"
      />
    </figure>
  </div>
</section>

<style>
  .why {
    padding-top: 2rem;
    padding-bottom: 2.5rem;
  }

  .why__showcase {
    margin: 0;
    border-radius: calc(var(--radius) + 6px);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow);
    background: var(--color-elevated-soft);
    line-height: 0;
  }

  .why__showcase img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .why {
      padding-top: 1.5rem;
      padding-bottom: 1.75rem;
    }
  }
</style>
