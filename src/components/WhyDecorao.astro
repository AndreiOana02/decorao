---
import site from '../data/site.json';

const icons = ['◇', '◆', '▣', '◎'];
---

<section class="section why" id="de-ce">
  <div class="container container--wide">
    <p class="section__eyebrow">Avantaje</p>
    <h2 class="section__title">{site.why.title}</h2>
    <p class="why__intro">{site.why.intro}</p>
    <div class="why__grid">
      {site.why.items.map((item, i) => (
        <article class="why__card">
          <span class="why__icon" aria-hidden="true">{icons[i % icons.length]}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why {
    position: relative;
    background:
      radial-gradient(ellipse 80% 50% at 50% 0%, rgba(139, 90, 43, 0.06), transparent 70%),
      var(--color-bg);
  }

  .why__intro {
    max-width: 52ch;
    color: var(--color-muted);
    margin: 0 0 2.5rem;
  }

  .why__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .why__card {
    padding: 1.75rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .why__card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
    border-color: rgba(139, 90, 43, 0.25);
  }

  .why__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    margin-bottom: 1rem;
    font-size: 1.1rem;
    color: var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: 12px;
  }

  .why__card h3 {
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.2rem;
  }

  .why__card p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }
</style>
