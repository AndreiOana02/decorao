---
import site from '../data/site.json';

const { materials } = site;
---

<section class="section materials" id="materiale" aria-label={materials.title}>
  <div class="container container--wide">
    <figure class="materials__showcase">
      <img
        src={materials.collageImage}
        alt={`${materials.title} — ${materials.intro} ${materials.intro2}`}
        width="1200"
        height="900"
        loading="lazy"
        decoding="async"
      />
    </figure>
  </div>
</section>

<style>
  .materials {
    padding-top: 2rem;
    padding-bottom: 2.5rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, #f3ede5 100%);
  }

  .materials__showcase {
    margin: 0;
    border-radius: calc(var(--radius) + 6px);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow);
    background: #faf8f5;
    line-height: 0;
  }

  .materials__showcase img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .materials {
      padding-top: 1.5rem;
      padding-bottom: 1.75rem;
    }
  }
</style>
