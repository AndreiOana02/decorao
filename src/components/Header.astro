---
import site from '../data/site.json';

import Logo from './Logo.astro';
import SocialLinks from './SocialLinks.astro';

const navMain = site.nav.filter((item) =>
  ['acasa', 'despre', 'materiale', 'contact'].includes(item.id)
);
const navRooms = site.nav.filter(
  (item) => !['acasa', 'despre', 'materiale', 'contact'].includes(item.id)
);
---

<header class="header">
  <div class="container container--wide header__bar">
    <a class="header__brand" href="#acasa">
      <Logo />
    </a>

    <div class="header__actions">
      <SocialLinks variant="icons" />
      <a class="btn btn--primary header__cta" href="#contact">Cere ofertă</a>
    </div>
  </div>

  <div class="container container--wide header__nav-wrap">
    <button class="header__toggle" type="button" aria-expanded="false" aria-controls="nav-menu">
      <span class="sr-only">Meniu</span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

    <nav class="header__nav" id="nav-menu" aria-label="Principal">
      <div class="header__nav-site">
        <p class="header__nav-label header__nav-label--site">Site</p>
        <ul class="header__nav-list header__nav-list--site">
          {navMain.map((item) => (
            <li>
              <a href={`#${item.id}`} data-nav={item.id}>{item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="header__nav-rooms">
        <p class="header__nav-label header__nav-label--cats">Categorii</p>
        <ul class="header__nav-list header__nav-list--rooms">
          {navRooms.map((item) => (
            <li>
              <a href={`#${item.id}`} data-nav={item.id}>{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(247, 243, 237, 0.94);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .header__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .header__brand {
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
    max-width: min(260px, 55vw);
    overflow: hidden;
  }

  .header__brand :global(.logo--full) {
    max-width: 100%;
  }

  .header__brand :global(.logo__mark) {
    width: 40px;
    height: 40px;
    max-width: 40px;
    max-height: 40px;
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .header__actions :global(.social--icons) {
    gap: 0.25rem;
  }

  .header__cta {
    flex-shrink: 0;
    padding: 0.55rem 1rem;
    font-size: 0.88rem;
  }

  @media (max-width: 480px) {
    .header__actions :global(.social--icons a) {
      width: 2rem;
      height: 2rem;
    }
  }

  .header__nav-wrap {
    position: relative;
    display: flex;
    align-items: stretch;
    padding: 0.55rem 0 0.7rem;
  }

  .header__nav {
    display: flex;
    align-items: flex-end;
    gap: 0.75rem;
    width: 100%;
  }

  .header__nav-site,
  .header__nav-rooms {
    flex: 0 0 calc(50% - 0.375rem);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.4rem;
    min-width: 0;
  }

  .header__nav-label--site,
  .header__nav-label--cats {
    margin: 0;
    width: 100%;
    text-align: center;
  }

  .header__nav-list--site {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__nav-list--rooms {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__nav-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .header__nav-list a {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2.35rem;
    padding: 0.45rem 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    font-weight: 600;
    font-size: clamp(0.78rem, 1.1vw, 0.9rem);
    line-height: 1.2;
    text-align: center;
    white-space: nowrap;
    background: rgba(255, 255, 255, 0.65);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    box-shadow: var(--shadow-sm);
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      color 0.15s ease,
      transform 0.15s ease;
  }

  .header__nav-list a:hover {
    color: var(--color-accent-dark);
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .header__nav-list a.is-active {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }

  .header__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    margin-right: 0.5rem;
    border: none;
    background: transparent;
    cursor: pointer;
    flex-shrink: 0;
  }

  .header__toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
  }

  @media (max-width: 1100px) {
    .header__nav {
      flex-direction: column;
      align-items: stretch;
      gap: 0.65rem;
    }

    .header__nav-site {
      flex: none;
      width: 100%;
    }

    .header__nav-rooms {
      flex: none;
      width: 100%;
    }

    .header__nav-list--rooms {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .header__toggle {
      display: flex;
    }

    .header__nav-wrap {
      flex-wrap: wrap;
      align-items: flex-start;
    }

    .header__nav {
      width: 100%;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s ease;
    }

    .header__nav.is-open {
      max-height: 560px;
      padding-bottom: 0.75rem;
    }

    .header__nav-list--site,
    .header__nav-list--rooms {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .header__nav-list a {
      min-height: 2.5rem;
      font-size: 0.9rem;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.header__toggle');
  const nav = document.querySelector('.header__nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });
  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      nav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  const navLinks = [...document.querySelectorAll('[data-nav]')];
  const sections = navLinks
    .map((link) => {
      const id = (link as HTMLElement).dataset.nav;
      const el = id ? document.getElementById(id) : null;
      return el ? { id, el, link } : null;
    })
    .filter(Boolean) as { id: string; el: HTMLElement; link: Element }[];

  if (sections.length > 0 && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => (b.intersectionRatio ?? 0) - (a.intersectionRatio ?? 0))[0];
        if (!visible) return;
        const id = visible.target.id;
        navLinks.forEach((link) => {
          link.classList.toggle('is-active', (link as HTMLElement).dataset.nav === id);
        });
      },
      { rootMargin: '-40% 0px -45% 0px', threshold: [0, 0.15, 0.4] }
    );
    sections.forEach(({ el }) => observer.observe(el));
  }
</script>
