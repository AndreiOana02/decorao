---
import site from '../data/site.json';
import SocialLinks from './SocialLinks.astro';

const tel = site.phoneTel ?? site.phone.replace(/\s/g, '');
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.mapsQuery ?? site.address)}`;
---

<section class="section contact">
  <div class="container container--wide contact__grid">
    <div>
      <p class="section__eyebrow">Contact</p>
      <h2 class="section__title">Hai să discutăm proiectul tău</h2>
      <p>
        Sună-ne, scrie pe e-mail sau pe rețelele sociale — cu dimensiunile spațiului și camera dorită
        revenim cu ofertă și termen estimat.
      </p>
      <SocialLinks variant="light" />
    </div>
    <address class="contact__card">
      <dl>
        <div>
          <dt>Telefon</dt>
          <dd><a href={`tel:${tel}`}>{site.phone}</a></dd>
        </div>
        <div>
          <dt>E-mail</dt>
          <dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
        </div>
        <div>
          <dt>Adresă</dt>
          <dd>
            <a href={mapsUrl} target="_blank" rel="noopener noreferrer">{site.address}</a>
          </dd>
        </div>
        <div>
          <dt>Program</dt>
          <dd>{site.hours}</dd>
        </div>
      </dl>
      <div class="contact__actions">
        <a class="btn btn--primary contact__btn" href={`tel:${tel}`}>Sună acum</a>
        <a class="btn btn--ghost contact__btn" href={`mailto:${site.email}?subject=Ofertă mobilă Decorao`}>
          Trimite e-mail
        </a>
      </div>
    </address>
  </div>
</section>

<style>
  .contact {
    background: linear-gradient(180deg, var(--color-bg) 0%, #ebe4d8 100%);
  }

  .contact :global(.social) {
    margin-top: 1.25rem;
  }

  .contact__actions {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  .contact__card {
    font-style: normal;
    padding: 1.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .contact__card dl {
    margin: 0 0 1.5rem;
  }

  .contact__card div {
    margin-bottom: 1rem;
  }

  .contact__card dt {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: 0.2rem;
  }

  .contact__card dd {
    margin: 0;
    font-size: 1.05rem;
  }

  .contact__btn {
    width: 100%;
    text-align: center;
  }

  @media (max-width: 900px) {
    .contact__grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
  }
</style>
