---
import site from '../data/site.json';
import HeroVisual from './HeroVisual.astro';
import type { GalerieItem } from '../lib/galerie';

interface Props {
  slides: GalerieItem[];
}

const { slides } = Astro.props;
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="container container--wide hero__grid">
    <div class="hero__panel" style={`--hero-panel-bg: url('${site.hero.panelImage}')`}>
      <p class="hero__eyebrow">Fabrică de mobilă · Dâmbovița</p>
      <h1 class="hero__title">
        <span class="hero__brand">{site.brand}</span>
      </h1>
      <p class="hero__subtitle">{site.tagline}</p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/contact">Solicită ofertă</a>
        <a class="btn btn--ghost" href="/bucatarii">Vezi lucrările</a>
      </div>
    </div>
    <div class="hero__aside">
      <HeroVisual images={slides} />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 2rem 0 3.5rem;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(155deg, rgba(247, 243, 237, 0.97) 0%, rgba(247, 243, 237, 0.85) 40%, transparent 70%),
      radial-gradient(ellipse 90% 60% at 80% 20%, rgba(139, 90, 43, 0.08), transparent 55%),
      linear-gradient(160deg, #ebe4d8 0%, var(--color-bg) 50%);
    z-index: 0;
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: clamp(1.75rem, 3vw, 3rem);
    align-items: stretch;
  }

  .hero__panel {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(1.5rem, 2.5vw, 2.25rem);
    overflow: hidden;
    background: linear-gradient(145deg, #f8f2ea 0%, #efe4d6 42%, #e6d9c8 100%);
    border: 1px solid rgba(139, 90, 43, 0.22);
    border-radius: calc(var(--radius) + 8px);
    box-shadow: var(--shadow), inset 0 1px 0 rgba(255, 255, 255, 0.65);
  }

  .hero__panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--hero-panel-bg);
    background-size: cover;
    background-position: 78% center;
    background-repeat: no-repeat;
    opacity: 0.2;
    pointer-events: none;
  }

  .hero__panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        105deg,
        rgba(248, 242, 234, 0.94) 0%,
        rgba(239, 228, 214, 0.82) 42%,
        rgba(230, 217, 200, 0.5) 68%,
        rgba(230, 217, 200, 0.12) 100%
      ),
      radial-gradient(ellipse 90% 80% at 100% 0%, rgba(196, 165, 116, 0.28), transparent 55%);
    pointer-events: none;
  }

  .hero__panel > * {
    position: relative;
    z-index: 1;
  }

  .hero__eyebrow {
    margin: 0 0 0.65rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero__title {
    margin: 0 0 0.5rem;
    line-height: 1.15;
  }

  .hero__brand {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 2.85rem);
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .hero__subtitle {
    margin: 0 0 1.35rem;
    max-width: 36ch;
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    font-weight: 400;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero__aside {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    max-width: 100%;
    overflow-anchor: none;
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .hero__aside {
      order: -1;
    }

    .hero__subtitle {
      max-width: none;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__actions .btn {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 1.25rem 0 2.5rem;
    }
  }
</style>
