---
import site from '../data/site.json';
import HeroVisual from './HeroVisual.astro';
import type { GalerieItem } from '../lib/galerie';

interface Props {
  slides: GalerieItem[];
}

const { slides } = Astro.props;
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="container container--wide hero__grid">
    <div class="hero__panel" style={`--hero-panel-bg: url('${site.hero.panelImage}')`}>
      <p class="hero__eyebrow">Fabrică de mobilă la comandă · Târgoviște, Dâmbovița</p>
      <h1 class="hero__title">
        Mobilă la comandă
        <span class="hero__brand">{site.brand}</span>
      </h1>
      <p class="hero__subtitle">{site.tagline} — bucătării, dormitoare, uși și scări.</p>
      <p class="hero__coverage">Montaj în București, Ilfov, Dâmbovița, Prahova, Argeș, Giurgiu, Teleorman și Ialomița.</p>
      <div class="hero__actions">
        <a class="btn btn--primary" href="/contact">Solicită ofertă</a>
        <a class="btn btn--ghost" href="/bucatarii">Vezi lucrările</a>
      </div>
    </div>
    <div class="hero__aside">
      <HeroVisual images={slides} />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 2rem 0 3.5rem;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background: var(--color-hero-bg);
    z-index: 0;
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: clamp(1.75rem, 3vw, 3rem);
    align-items: stretch;
  }

  .hero__panel {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(1.5rem, 2.5vw, 2.25rem);
    overflow: hidden;
    background: var(--color-hero-panel);
    border: 1px solid rgba(139, 90, 43, 0.22);
    border-radius: calc(var(--radius) + 8px);
    box-shadow: var(--shadow), inset 0 1px 0 var(--color-section-inset);
  }

  .hero__panel::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: var(--hero-panel-bg);
    background-size: cover;
    background-position: 78% center;
    background-repeat: no-repeat;
    opacity: 0.2;
    pointer-events: none;
  }

  .hero__panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-hero-panel-overlay);
    pointer-events: none;
  }

  .hero__panel > * {
    position: relative;
    z-index: 1;
  }

  .hero__eyebrow {
    margin: 0 0 0.65rem;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .hero__title {
    margin: 0 0 0.5rem;
    line-height: 1.15;
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 3.2vw, 2.1rem);
    font-weight: 500;
    color: var(--color-text);
  }

  .hero__brand {
    display: block;
    margin-top: 0.15rem;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 2.85rem);
    font-weight: 500;
    color: var(--color-accent-dark);
    letter-spacing: 0.02em;
  }

  .hero__subtitle {
    margin: 0 0 0.5rem;
    max-width: 42ch;
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    font-weight: 400;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .hero__coverage {
    margin: 0 0 1.35rem;
    max-width: 42ch;
    font-size: clamp(0.92rem, 1.6vw, 1.05rem);
    font-weight: 500;
    color: var(--color-muted);
    line-height: 1.45;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero__aside {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    max-width: 100%;
    overflow-anchor: none;
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .hero__aside {
      order: -1;
    }

    .hero__subtitle,
    .hero__coverage {
      max-width: none;
    }

    .hero__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero__actions .btn {
      width: 100%;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 1.25rem 0 2.5rem;
    }
  }
</style>
