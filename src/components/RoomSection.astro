---

import type { GalerieItem } from '../lib/galerie';



interface Props {

  id: string;

  title: string;

  intro: string;

  features: string[];

  images: GalerieItem[];

  altBg?: boolean;

}



const { id, title, intro, features, images, altBg = false } = Astro.props;

---



<section class:list={['section', 'room', { 'section--alt': altBg }]} id={id}>

  <div class="container container--wide">

    <p class="section__eyebrow">Mobilă la comandă</p>

    <h2 class="section__title">{title}</h2>

    <p class="room__intro">{intro}</p>

    <ul class="room__features">

      {features.map((f) => (

        <li>{f}</li>

      ))}

    </ul>



    {images.length > 0 ? (

      <div class="gallery">

        {images.map((item) => (

          <figure class="gallery__item">

            <button
              type="button"
              class:list={[
                'gallery__trigger',
                `gallery__trigger--${item.orientation ?? 'landscape'}`,
                { 'gallery__trigger--contain': item.fit === 'contain' },
              ]}
              data-lightbox
              data-src={item.src}
              data-alt={item.title}
              aria-label={`Mărește: ${item.title}`}
            >
              <img src={item.src} alt={item.title} loading="lazy" width="480" height="360" />
            </button>

            <figcaption>{item.title}</figcaption>

          </figure>

        ))}

      </div>

    ) : (

      <div class="gallery-empty">

        <p>

          Poze pentru <strong>{title}</strong>: adaugă imagini în

          <code>public/galerie/{id}/</code>

        </p>

      </div>

    )}

  </div>

</section>



<style>

  .room {
    overflow-x: clip;
  }

  .room .section__title {
    margin-bottom: 0.5rem;
  }

  .room .section__title::after {
    margin-top: 0.45rem;
  }

  .room__intro {

    color: var(--color-muted);

    margin: 0 0 0.65rem;

    line-height: 1.5;

  }



  .room__features {

    display: flex;

    flex-wrap: wrap;

    align-items: baseline;

    gap: 0.35rem 0.85rem;

    list-style: none;

    margin: 0 0 1rem;

    padding: 0;

    max-width: 100%;

  }

  .room .section__eyebrow {
    margin-bottom: 0.35rem;
  }



  .room__features li {

    position: relative;

    flex: 0 0 auto;

    padding-left: 0.9rem;

    color: var(--color-text);

    font-size: 0.875rem;

    line-height: 1.4;

  }



  .room__features li::before {

    content: '';

    position: absolute;

    left: 0;

    top: 0.55em;

    width: 6px;

    height: 6px;

    border-radius: 50%;

    background: var(--color-accent);

  }



  .gallery {

    display: grid;

    grid-template-columns: repeat(2, minmax(0, 1fr));

    gap: 1rem;

    width: 100%;

    max-width: 100%;

    min-width: 0;

    align-items: start;

  }

  @media (min-width: 640px) {

    .gallery {

      grid-template-columns: repeat(auto-fill, minmax(11.5rem, 1fr));

    }

  }

  @media (min-width: 1100px) {

    .gallery {

      grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));

    }

  }

  @media (max-width: 480px) {

    .gallery {

      grid-template-columns: 1fr;

      gap: 0.85rem;

    }

  }



  .gallery__item {

    margin: 0;

    min-width: 0;

    border-radius: var(--radius);

    overflow: hidden;

    background: var(--color-surface);

    border: 1px solid var(--color-border);

    box-shadow: var(--shadow-sm);

    transition: box-shadow 0.2s ease;

  }



  .gallery__item:hover {

    box-shadow: var(--shadow);

  }



  .gallery__trigger {

    position: relative;

    display: block;

    width: 100%;

    aspect-ratio: 4 / 3;

    overflow: hidden;

    padding: 0;

    border: none;

    background: var(--color-elevated);

    cursor: zoom-in;

  }

  .gallery__trigger--portrait {
    aspect-ratio: 3 / 4;
  }

  .gallery__trigger--square {
    aspect-ratio: 1 / 1;
  }

  .gallery__trigger img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: transform 0.35s ease;
  }

  .gallery__item:hover .gallery__trigger img {

    transform: scale(1.02);

  }



  .gallery__item figcaption {

    padding: 0.75rem 0.85rem;

    font-size: 0.9rem;

    line-height: 1.35;

    color: var(--color-muted);

    overflow-wrap: anywhere;

  }



  .gallery-empty {

    padding: 1.5rem;

    border: 2px dashed var(--color-border);

    border-radius: var(--radius);

    color: var(--color-muted);

    font-size: 0.95rem;

  }



  .gallery-empty code {

    color: var(--color-accent-dark);

  }

</style>


