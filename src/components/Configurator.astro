---
import site from '../data/site.json';
import config from '../data/configurator.json';

const rooms = site.rooms.map((r) => ({ id: r.id, label: r.label, title: r.title }));
const tel = site.phoneTel ?? site.phone.replace(/\s/g, '');
---

<section class="section configurator" id="configurator">
  <div class="container container--wide">
    <p class="section__eyebrow">Configurator</p>
    <h1 class="section__title">{config.title}</h1>
    <p class="configurator__intro">{config.intro}</p>

    <div class="configurator__layout">
      <div class="configurator__main">
        <ol class="configurator__steps" aria-label="Pași configurare">
          {config.steps.map((step, i) => (
            <li>
              <button
                type="button"
                class="configurator__step-btn"
                data-step-nav={step.id}
                data-step-index={i}
                aria-current={i === 0 ? 'step' : undefined}
              >
                <span class="configurator__step-num">{i + 1}</span>
                <span class="configurator__step-label">{step.label}</span>
              </button>
            </li>
          ))}
        </ol>

        <div class="configurator__panels">
          <div class="configurator__panel is-active" data-step-panel="room">
            <h2 class="configurator__panel-title">Ce cameră vrei să amenajezi?</h2>
            <div class="configurator__cards" role="group" aria-label="Alege camera">
              {rooms.map((room) => (
                <button type="button" class="configurator__card" data-room={room.id}>
                  <span class="configurator__card-label">{room.label}</span>
                  <span class="configurator__card-hint">{room.title}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="configurator__panel" data-step-panel="material" hidden>
            <h2 class="configurator__panel-title">Ce materiale preferi?</h2>
            <div class="configurator__cards configurator__cards--materials" role="group" aria-label="Alege materialul">
              {config.materials.map((mat) => (
                <button type="button" class="configurator__card configurator__card--material" data-material={mat.id}>
                  <span class="configurator__card-label">{mat.label}</span>
                  <span class="configurator__card-hint">{mat.description}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="configurator__panel" data-step-panel="finish" hidden>
            <h2 class="configurator__panel-title">Finisaj și culoare</h2>
            <fieldset class="configurator__fieldset">
              <legend>Tip finisaj</legend>
              <div class="configurator__chips" role="group" aria-label="Finisaj">
                {config.finishes.map((f) => (
                  <button type="button" class="configurator__chip" data-finish={f.id}>
                    {f.label}
                  </button>
                ))}
              </div>
            </fieldset>
            <fieldset class="configurator__fieldset">
              <legend>Culoare principală</legend>
              <div class="configurator__swatches" role="group" aria-label="Culoare">
                {config.colors.map((c) => (
                  <button
                    type="button"
                    class="configurator__swatch"
                    data-color={c.id}
                    data-hex={c.hex}
                    title={c.label}
                    aria-label={c.label}
                    style={`--swatch: ${c.hex}`}
                  >
                    <span class="configurator__swatch-label">{c.label}</span>
                  </button>
                ))}
              </div>
            </fieldset>
          </div>

          <div class="configurator__panel" data-step-panel="dimensions" hidden>
            <h2 class="configurator__panel-title">Dimensiuni aproximative</h2>
            <p class="configurator__hint" data-dimension-hint>
              Completează dimensiunile — la măsurători le confirmăm la locație.
            </p>
            <div class="configurator__dims">
              <label>
                Lățime (cm)
                <input type="text" name="width" inputmode="numeric" placeholder="ex. 320" data-dim="width" />
              </label>
              <label>
                Înălțime (cm)
                <input type="text" name="height" inputmode="numeric" placeholder="ex. 240" data-dim="height" />
              </label>
              <label>
                Adâncime (cm)
                <input type="text" name="depth" inputmode="numeric" placeholder="ex. 60" data-dim="depth" />
              </label>
            </div>
            <label class="configurator__notes-label">
              Observații suplimentare
              <textarea
                name="notes"
                rows="3"
                placeholder="Ex.: perete cu cotitură, fereastră pe perete lateral..."
                data-dim="notes"
              ></textarea>
            </label>
          </div>

          <div class="configurator__panel" data-step-panel="extras" hidden>
            <h2 class="configurator__panel-title">Detalii pentru proiectul tău</h2>
            <p class="configurator__hint">Bifează ce te interesează — poți alege mai multe.</p>
            <div class="configurator__extras" data-extras-list></div>
          </div>

          <div class="configurator__panel" data-step-panel="summary" hidden>
            <h2 class="configurator__panel-title">Rezumatul proiectului tău</h2>
            <pre class="configurator__summary-text" data-summary-text></pre>
            <p class="configurator__hint">
              Trimite rezumatul către Decorao — revenim cu ofertă și termen estimat.
            </p>
            <div class="configurator__send">
              <a class="btn btn--primary" href="#" data-send="whatsapp" target="_blank" rel="noopener noreferrer">
                Trimite pe WhatsApp
              </a>
              <a class="btn btn--ghost" href="#" data-send="email">Trimite e-mail</a>
              <button type="button" class="btn btn--ghost" data-send="copy">Copiază rezumatul</button>
              <a class="btn btn--ghost" href={`tel:${tel}`}>Sună {site.phone}</a>
            </div>
            <p class="configurator__copy-status" data-copy-status hidden>Rezumat copiat în clipboard.</p>
          </div>
        </div>

        <div class="configurator__nav">
          <button type="button" class="btn btn--ghost" data-action="prev" disabled>Înapoi</button>
          <button type="button" class="btn btn--primary" data-action="next">Continuă</button>
        </div>
      </div>

      <aside class="configurator__preview" aria-label="Previzualizare">
        <p class="configurator__preview-label">Previzualizare</p>
        <div class="configurator__preview-scene" data-preview-scene>
          <div class="configurator__preview-wall"></div>
          <div class="configurator__preview-unit" data-preview-unit>
            <div class="configurator__preview-top" data-preview-top></div>
            <div class="configurator__preview-body" data-preview-body></div>
            <div class="configurator__preview-accent" data-preview-accent></div>
          </div>
        </div>
        <dl class="configurator__preview-list" data-preview-list>
          <div><dt>Camera</dt><dd data-preview-room>—</dd></div>
          <div><dt>Material</dt><dd data-preview-material>—</dd></div>
          <div><dt>Finisaj</dt><dd data-preview-finish>—</dd></div>
          <div><dt>Culoare</dt><dd data-preview-color>—</dd></div>
        </dl>
      </aside>
    </div>
  </div>
</section>

<script define:vars={{ rooms, config, sitePhone: site.phone, siteEmail: site.email, siteTel: tel }}>
  const STEP_IDS = config.steps.map((s) => s.id);
  let currentStep = 0;

  const state = {
    room: '',
    material: '',
    finish: '',
    color: '',
    colorHex: '#d4c4a8',
    width: '',
    height: '',
    depth: '',
    notes: '',
    extras: [],
  };

  const panels = document.querySelectorAll('[data-step-panel]');
  const stepBtns = document.querySelectorAll('[data-step-nav]');
  const prevBtn = document.querySelector('[data-action="prev"]');
  const nextBtn = document.querySelector('[data-action="next"]');
  const extrasList = document.querySelector('[data-extras-list]');
  const dimensionHint = document.querySelector('[data-dimension-hint]');
  const summaryText = document.querySelector('[data-summary-text]');
  const copyStatus = document.querySelector('[data-copy-status]');

  const previewRoom = document.querySelector('[data-preview-room]');
  const previewMaterial = document.querySelector('[data-preview-material]');
  const previewFinish = document.querySelector('[data-preview-finish]');
  const previewColor = document.querySelector('[data-preview-color]');
  const previewBody = document.querySelector('[data-preview-body]');
  const previewTop = document.querySelector('[data-preview-top]');
  const previewAccent = document.querySelector('[data-preview-accent]');
  const previewUnit = document.querySelector('[data-preview-unit]');

  const roomMap = Object.fromEntries(rooms.map((r) => [r.id, r.label]));
  const materialMap = Object.fromEntries(config.materials.map((m) => [m.id, m.label]));
  const finishMap = Object.fromEntries(config.finishes.map((f) => [f.id, f.label]));
  const colorMap = Object.fromEntries(config.colors.map((c) => [c.id, c.label]));

  function labelFor(id, map) {
    return id ? map[id] ?? id : '—';
  }

  function updatePreview() {
    previewRoom.textContent = labelFor(state.room, roomMap);
    previewMaterial.textContent = labelFor(state.material, materialMap);
    previewFinish.textContent = labelFor(state.finish, finishMap);
    previewColor.textContent = labelFor(state.color, colorMap);

    const bodyColor = state.colorHex || '#d4c4a8';
    previewBody.style.background = bodyColor;
    previewTop.style.background =
      state.material === 'lemn' ? '#8b6914' : state.finish === 'lucios' ? `color-mix(in srgb, ${bodyColor} 75%, white)` : bodyColor;
    previewAccent.style.background = state.material === 'mix' || state.material === 'lemn' ? '#6b4423' : 'transparent';

    previewUnit.dataset.room = state.room || 'default';
  }

  function setActiveChip(selector, attr, value, multi = false) {
    document.querySelectorAll(selector).forEach((el) => {
      const match = el.getAttribute(attr) === value;
      if (multi) {
        const id = el.getAttribute(attr);
        el.classList.toggle('is-selected', state.extras.includes(id));
      } else {
        el.classList.toggle('is-selected', match);
      }
    });
  }

  function renderExtras() {
    if (!extrasList) return;
    const roomExtras = config.roomExtras[state.room];
    extrasList.innerHTML = '';
    if (!roomExtras) {
      extrasList.innerHTML = '<p class="configurator__hint">Alege mai întâi o cameră la pasul 1.</p>';
      return;
    }
    roomExtras.options.forEach((opt) => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'configurator__chip';
      btn.dataset.extra = opt.id;
      btn.textContent = opt.label;
      btn.classList.toggle('is-selected', state.extras.includes(opt.id));
      btn.addEventListener('click', () => {
        if (state.extras.includes(opt.id)) {
          state.extras = state.extras.filter((x) => x !== opt.id);
        } else {
          state.extras.push(opt.id);
        }
        setActiveChip('[data-extra]', 'data-extra', opt.id, true);
      });
      extrasList.appendChild(btn);
    });
  }

  function updateDimensionHint() {
    const roomExtras = config.roomExtras[state.room];
    if (dimensionHint && roomExtras?.dimensionHint) {
      dimensionHint.textContent = roomExtras.dimensionHint;
    }
  }

  function buildSummary() {
    const lines = [
      'Bună ziua, aș dori o ofertă pentru mobilă la comandă — Decorao.',
      '',
      `Camera: ${labelFor(state.room, roomMap)}`,
      `Material: ${labelFor(state.material, materialMap)}`,
      `Finisaj: ${labelFor(state.finish, finishMap)}`,
      `Culoare: ${labelFor(state.color, colorMap)}`,
    ];

    const dims = [state.width, state.height, state.depth].filter(Boolean);
    if (dims.length) {
      lines.push(
        `Dimensiuni (aprox.): ${state.width ? `L ${state.width} cm` : ''}${state.height ? `, Î ${state.height} cm` : ''}${state.depth ? `, A ${state.depth} cm` : ''}`.replace(/^, /, '')
      );
    }

    const roomExtras = config.roomExtras[state.room];
    if (state.extras.length && roomExtras) {
      const labels = state.extras
        .map((id) => roomExtras.options.find((o) => o.id === id)?.label)
        .filter(Boolean);
      lines.push(`Detalii: ${labels.join(', ')}`);
    }

    if (state.notes.trim()) {
      lines.push(`Observații: ${state.notes.trim()}`);
    }

    lines.push('', 'Mulțumesc!');
    return lines.join('\n');
  }

  function updateSummary() {
    const text = buildSummary();
    if (summaryText) summaryText.textContent = text;

    const encoded = encodeURIComponent(text);
    const wa = document.querySelector('[data-send="whatsapp"]');
    const email = document.querySelector('[data-send="email"]');
    if (wa) wa.href = `https://wa.me/${siteTel.replace(/\D/g, '')}?text=${encoded}`;
    if (email) {
      email.href = `mailto:${siteEmail}?subject=${encodeURIComponent('Cerere ofertă — Configurator Decorao')}&body=${encoded}`;
    }
  }

  function showStep(index) {
    currentStep = Math.max(0, Math.min(index, STEP_IDS.length - 1));
    const stepId = STEP_IDS[currentStep];

    panels.forEach((panel) => {
      const active = panel.getAttribute('data-step-panel') === stepId;
      panel.classList.toggle('is-active', active);
      panel.hidden = !active;
    });

    stepBtns.forEach((btn, i) => {
      btn.setAttribute('aria-current', i === currentStep ? 'step' : 'false');
      btn.classList.toggle('is-done', i < currentStep);
    });

    if (prevBtn) prevBtn.disabled = currentStep === 0;
    if (nextBtn) {
      nextBtn.textContent = currentStep === STEP_IDS.length - 1 ? 'Finalizează' : 'Continuă';
      nextBtn.hidden = currentStep === STEP_IDS.length - 1;
    }

    if (stepId === 'extras') renderExtras();
    if (stepId === 'summary') updateSummary();
    if (stepId === 'dimensions') updateDimensionHint();
  }

  function canAdvance() {
    const stepId = STEP_IDS[currentStep];
    if (stepId === 'room') return !!state.room;
    if (stepId === 'material') return !!state.material;
    if (stepId === 'finish') return !!state.finish && !!state.color;
    return true;
  }

  document.querySelectorAll('[data-room]').forEach((btn) => {
    btn.addEventListener('click', () => {
      state.room = btn.getAttribute('data-room') ?? '';
      state.extras = [];
      setActiveChip('[data-room]', 'data-room', state.room);
      updatePreview();
      updateDimensionHint();
      renderExtras();
    });
  });

  document.querySelectorAll('[data-material]').forEach((btn) => {
    btn.addEventListener('click', () => {
      state.material = btn.getAttribute('data-material') ?? '';
      setActiveChip('[data-material]', 'data-material', state.material);
      updatePreview();
    });
  });

  document.querySelectorAll('[data-finish]').forEach((btn) => {
    btn.addEventListener('click', () => {
      state.finish = btn.getAttribute('data-finish') ?? '';
      setActiveChip('[data-finish]', 'data-finish', state.finish);
      updatePreview();
    });
  });

  document.querySelectorAll('[data-color]').forEach((btn) => {
    btn.addEventListener('click', () => {
      state.color = btn.getAttribute('data-color') ?? '';
      state.colorHex = btn.getAttribute('data-hex') ?? '#d4c4a8';
      setActiveChip('[data-color]', 'data-color', state.color);
      updatePreview();
    });
  });

  document.querySelectorAll('[data-dim]').forEach((input) => {
    input.addEventListener('input', () => {
      const key = input.getAttribute('data-dim');
      if (key && key in state) state[key] = input.value;
    });
  });

  stepBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const index = Number(btn.getAttribute('data-step-index'));
      if (index <= currentStep) showStep(index);
    });
  });

  prevBtn?.addEventListener('click', () => showStep(currentStep - 1));
  nextBtn?.addEventListener('click', () => {
    if (!canAdvance()) return;
    if (currentStep < STEP_IDS.length - 1) showStep(currentStep + 1);
  });

  document.querySelector('[data-send="copy"]')?.addEventListener('click', async () => {
    const text = buildSummary();
    try {
      await navigator.clipboard.writeText(text);
      if (copyStatus) {
        copyStatus.hidden = false;
        setTimeout(() => {
          copyStatus.hidden = true;
        }, 2500);
      }
    } catch {
      if (summaryText) {
        const range = document.createRange();
        range.selectNode(summaryText);
        window.getSelection()?.removeAllRanges();
        window.getSelection()?.addRange(range);
      }
    }
  });

  updatePreview();
  showStep(0);
</script>

<style>
  .configurator__intro {
    max-width: 42rem;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.55;
    margin: 0 0 2rem;
  }

  .configurator__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(240px, 300px);
    gap: 2rem;
    align-items: start;
  }

  .configurator__steps {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
  }

  .configurator__step-btn {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    color: var(--color-muted);
    font: inherit;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }

  .configurator__step-btn[aria-current='step'] {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-on-accent);
  }

  .configurator__step-btn.is-done {
    color: var(--color-accent-dark);
    border-color: var(--color-accent);
  }

  .configurator__step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.35rem;
    height: 1.35rem;
    border-radius: 50%;
    background: var(--color-accent-soft);
    font-size: 0.72rem;
  }

  .configurator__step-btn[aria-current='step'] .configurator__step-num {
    background: rgba(255, 255, 255, 0.2);
  }

  .configurator__main {
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }

  .configurator__panel-title {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .configurator__cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
  }

  .configurator__cards--materials {
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  }

  .configurator__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
    padding: 1rem;
    text-align: left;
    border: 2px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-elevated-soft);
    cursor: pointer;
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }

  .configurator__card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .configurator__card.is-selected {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
    box-shadow: var(--shadow-sm);
  }

  .configurator__card-label {
    font-weight: 700;
    color: var(--color-text);
  }

  .configurator__card-hint {
    font-size: 0.82rem;
    color: var(--color-muted);
    line-height: 1.4;
  }

  .configurator__fieldset {
    border: none;
    margin: 0 0 1.25rem;
    padding: 0;
  }

  .configurator__fieldset legend {
    font-weight: 700;
    margin-bottom: 0.65rem;
    color: var(--color-text);
  }

  .configurator__chips,
  .configurator__extras {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .configurator__chip {
    padding: 0.55rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-elevated-soft);
    color: var(--color-text);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
  }

  .configurator__chip.is-selected {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-on-accent);
  }

  .configurator__swatches {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(88px, 1fr));
    gap: 0.65rem;
  }

  .configurator__swatch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem;
    border: 2px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    cursor: pointer;
  }

  .configurator__swatch::before {
    content: '';
    display: block;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 8px;
    background: var(--swatch);
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.08);
  }

  .configurator__swatch.is-selected {
    border-color: var(--color-accent);
  }

  .configurator__swatch-label {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-muted);
    text-align: center;
  }

  .configurator__hint {
    color: var(--color-muted);
    font-size: 0.92rem;
    margin: 0 0 1rem;
  }

  .configurator__dims {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .configurator__dims label,
  .configurator__notes-label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-muted);
  }

  .configurator__dims input,
  .configurator__notes-label textarea {
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-elevated-soft);
    color: var(--color-text);
    font: inherit;
    font-size: 1rem;
  }

  .configurator__summary-text {
    white-space: pre-wrap;
    font-family: inherit;
    font-size: 0.92rem;
    line-height: 1.5;
    padding: 1rem;
    margin: 0 0 1rem;
    background: var(--color-elevated-soft);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    overflow-x: auto;
  }

  .configurator__send {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.65rem;
  }

  .configurator__send .btn {
    text-align: center;
  }

  .configurator__copy-status {
    margin: 0.75rem 0 0;
    font-size: 0.88rem;
    color: var(--color-accent-dark);
    font-weight: 600;
  }

  .configurator__nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.5rem;
