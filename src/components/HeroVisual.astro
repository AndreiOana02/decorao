---
import type { GalerieItem } from '../lib/galerie';

interface Props {
  images: GalerieItem[];
}

const { images } = Astro.props;
const slides =
  images.length > 0
    ? images
    : [{ src: '/galerie/bucatarii/bucatarie-01.png', title: 'Bucătărie Decorao' }];
const showDots = slides.length > 1 && slides.length <= 14;
const showCounter = slides.length > 14;
---

<div
  class="hero-visual hero__visual"
  data-hero-carousel
  data-slides={JSON.stringify(slides)}
>
  <div class="hero-visual__slot">
    <div
      class:list={[
        'hero-visual__frame',
        `hero-visual__frame--${slides[0].orientation ?? 'landscape'}`,
        { 'hero-visual__frame--contain': slides[0].fit === 'contain' },
      ]}
      data-hero-frame
      tabindex="-1"
      role="region"
      aria-roledescription="carusel"
      aria-label="Imagini prezentare — glisează stânga/dreapta"
    >
    <figure class="hero-visual__slide is-active">
      <img
        src={slides[0].src}
        alt={slides[0].title}
        width="720"
        height="540"
        fetchpriority="high"
        decoding="async"
        draggable="false"
        data-hero-img
      />
    </figure>
    {slides.length > 1 && (
      <>
        <button type="button" class="hero-visual__nav hero-visual__nav--prev" data-hero-prev aria-label="Imaginea anterioară">
          ‹
        </button>
        <button type="button" class="hero-visual__nav hero-visual__nav--next" data-hero-next aria-label="Imaginea următoare">
          ›
        </button>
      </>
    )}
    <div class="hero-visual__overlay" aria-hidden="true"></div>
    {showDots && (
      <div class="hero-visual__dots" role="tablist" aria-label="Imagini hero">
        {slides.map((_, i) => (
          <button
            type="button"
            class:list={['hero-visual__dot', { 'is-active': i === 0 }]}
            data-dot={i}
            aria-label={`Imagine ${i + 1}`}
            aria-selected={i === 0 ? 'true' : 'false'}
          />
        ))}
      </div>
    )}
    {showCounter && (
      <p class="hero-visual__counter" data-hero-counter aria-live="polite">
        1 / {slides.length}
      </p>
    )}
  </div>
  </div>
  {slides.length > 1 && (
    <p class="hero-visual__caption" data-hero-caption>
      {slides[0].title}
    </p>
  )}
</div>

<style>
  .hero-visual {
    width: 100%;
    max-width: 28rem;
    margin: 0 auto;
  }

  /* Slot fix — pagina nu sare; conținutul se adaptează în interior */
  .hero-visual__slot {
    width: 100%;
    height: min(22rem, 52vh);
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-visual__frame {
    position: relative;
    width: 100%;
    height: 100%;
    max-width: 100%;
    border-radius: calc(var(--radius) * 1.5);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-lg);
    background: var(--color-elevated);
    touch-action: pan-y pinch-zoom;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }

  .hero-visual__frame--portrait {
    width: auto;
    max-width: min(16rem, 72%);
    aspect-ratio: 3 / 4;
    height: 100%;
    max-height: 100%;
  }

  .hero-visual__frame--square {
    width: auto;
    max-width: min(18rem, 78%);
    aspect-ratio: 1 / 1;
    height: auto;
    max-height: 100%;
  }

  .hero-visual__frame.is-dragging {
    cursor: grabbing;
  }

  .hero-visual__slide {
    margin: 0;
    width: 100%;
    height: 100%;
  }

  .hero-visual__slide img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    pointer-events: none;
    -webkit-user-drag: none;
  }

  .hero-visual__nav {
    position: absolute;
    top: 50%;
    z-index: 3;
    transform: translateY(-50%);
    width: 2.5rem;
    height: 2.5rem;
    padding: 0;
    border: none;
    border-radius: 50%;
    font-size: 1.75rem;
    line-height: 1;
    color: #fff;
    background: rgba(28, 25, 23, 0.5);
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .hero-visual__nav:hover {
    background: rgba(139, 90, 43, 0.85);
  }

  .hero-visual__nav--prev {
    left: 0.75rem;
  }

  .hero-visual__nav--next {
    right: 0.75rem;
  }

  .hero-visual__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(28, 25, 23, 0.15) 0%,
      transparent 45%,
      rgba(139, 90, 43, 0.12) 100%
    );
    pointer-events: none;
  }

  .hero-visual__dots {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.35rem;
    max-width: 90%;
    z-index: 2;
  }

  .hero-visual__dot {
    width: 7px;
    height: 7px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.45);
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .hero-visual__dot.is-active {
    background: #fff;
    transform: scale(1.2);
  }

  .hero-visual__counter {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    margin: 0;
    padding: 0.35rem 0.65rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: #fff;
    background: rgba(28, 25, 23, 0.55);
    border-radius: 999px;
    z-index: 2;
  }

  .hero-visual__caption {
    margin: 0.75rem 0 0;
    min-height: 2.75em;
    font-size: 0.88rem;
    color: var(--color-muted);
    text-align: center;
    font-style: italic;
    line-height: 1.4;
  }
</style>

<script>
  function initHeroCarousel() {
    const root = document.querySelector('[data-hero-carousel]');
    if (!root || root.hasAttribute('data-hero-ready')) return;

    type Slide = {
      src: string;
      title: string;
      fit?: 'cover' | 'contain';
      orientation?: 'portrait' | 'landscape' | 'square';
    };
    let slides: Slide[] = [];
    try {
      slides = JSON.parse(root.getAttribute('data-slides') ?? '[]') as Slide[];
    } catch {
      slides = [];
    }
    if (slides.length < 2) return;

    root.setAttribute('data-hero-ready', '');

    const frame = root.querySelector('[data-hero-frame]') as HTMLElement;
    const img = root.querySelector('[data-hero-img]') as HTMLImageElement;
    const dots = [...root.querySelectorAll('[data-dot]')];
    const caption = root.querySelector('[data-hero-caption]');
    const counter = root.querySelector('[data-hero-counter]');
    const btnPrev = root.querySelector('[data-hero-prev]');
    const btnNext = root.querySelector('[data-hero-next]');

    let current = 0;
    let timer: ReturnType<typeof setInterval> | undefined;
    const SWIPE_PX = 40;
    let startX = 0;
    let startY = 0;
    let dragging = false;

    function preload(index: number) {
      const s = slides[index];
      if (!s) return;
      new Image().src = s.src;
    }

    function applySlideLayout(slide: Slide) {
      const orient = slide.orientation ?? 'landscape';
      frame.classList.remove(
        'hero-visual__frame--portrait',
        'hero-visual__frame--landscape',
        'hero-visual__frame--square',
        'hero-visual__frame--contain'
      );
      frame.classList.add(`hero-visual__frame--${orient}`);
      if (slide.fit === 'contain') frame.classList.add('hero-visual__frame--contain');
    }

    function goTo(index: number) {
      current = (index + slides.length) % slides.length;
      const slide = slides[current];
      img.src = slide.src;
      img.alt = slide.title;
      applySlideLayout(slide);
      dots.forEach((el, i) => {
        el.classList.toggle('is-active', i === current);
        el.setAttribute('aria-selected', String(i === current));
      });
      if (caption) caption.textContent = slide.title;
      if (counter) counter.textContent = `${current + 1} / ${slides.length}`;
      preload((current + 1) % slides.length);
    }

    function startAutoplay() {
      if (timer) clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 5500);
    }

    function pauseAutoplay() {
      if (timer) clearInterval(timer);
      timer = undefined;
    }

    function onSwipe(deltaX: number) {
      if (Math.abs(deltaX) < SWIPE_PX) return;
      goTo(deltaX < 0 ? current + 1 : current - 1);
    }

    function bump(dir: -1 | 1) {
      goTo(current + dir);
      pauseAutoplay();
      startAutoplay();
    }

    btnPrev?.addEventListener('click', (e) => {
      e.preventDefault();
      bump(-1);
    });
    btnNext?.addEventListener('click', (e) => {
      e.preventDefault();
      bump(1);
    });

    frame.addEventListener(
      'touchstart',
      (e) => {
        if (e.touches.length !== 1) return;
        startX = e.touches[0].clientX;
        startY = e.touches[0].clientY;
        dragging = true;
        pauseAutoplay();
      },
      { passive: true }
    );

    frame.addEventListener(
      'touchend',
      (e) => {
        if (!dragging) return;
        dragging = false;
        const touch = e.changedTouches[0];
        if (touch) {
          const dx = touch.clientX - startX;
          const dy = touch.clientY - startY;
          if (Math.abs(dx) > Math.abs(dy)) onSwipe(dx);
        }
        startAutoplay();
      },
      { passive: true }
    );

    frame.addEventListener('touchcancel', () => {
      dragging = false;
      startAutoplay();
    });

    frame.addEventListener('mousedown', (e) => {
      if (e.button !== 0) return;
      dragging = true;
      startX = e.clientX;
      frame.classList.add('is-dragging');
      pauseAutoplay();
      e.preventDefault();
    });

    window.addEventListener('mouseup', (e) => {
      if (!dragging) return;
      dragging = false;
      frame.classList.remove('is-dragging');
      onSwipe(e.clientX - startX);
      startAutoplay();
    });

    img.addEventListener('dragstart', (e) => e.preventDefault());

    root.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') bump(-1);
      else if (e.key === 'ArrowRight') bump(1);
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        goTo(Number((dot as HTMLElement).dataset.dot));
        pauseAutoplay();
        startAutoplay();
      });
    });

    preload(1);
    goTo(0);
    startAutoplay();
  }

  initHeroCarousel();
  document.addEventListener('astro:page-load', initHeroCarousel);
</script>
