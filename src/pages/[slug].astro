---
import PageShell from '../components/PageShell.astro';
import RoomSection from '../components/RoomSection.astro';
import WhyDecorao from '../components/WhyDecorao.astro';
import HowWeWork from '../components/HowWeWork.astro';
import MaterialsShowcase from '../components/MaterialsShowcase.astro';
import ContactSection from '../components/ContactSection.astro';
import site from '../data/site.json';
import { SITE_PAGE_IDS } from '../lib/nav';
import { getGalerieForRoom } from '../lib/galerie';
import { getPageSeo, getRoomSeo } from '../lib/seo';

export function getStaticPaths() {
  const pages = SITE_PAGE_IDS.map((slug) => ({ params: { slug } }));
  const rooms = site.rooms.map((room) => ({ params: { slug: room.id } }));
  return [...pages, ...rooms];
}

const { slug } = Astro.params;
const room = site.rooms.find((r) => r.id === slug);
const pagePath = `/${slug}`;
const pageSeo = slug ? getPageSeo(slug) : null;
const roomSeo = room ? getRoomSeo(room.id) : null;
const seoTitle = roomSeo?.title ?? pageSeo?.title;
const seoDescription = roomSeo?.description ?? pageSeo?.description;
const breadcrumbs = [
  { label: 'Acasă', href: '/' },
  {
    label: room?.label ?? (slug === 'despre' ? 'Despre' : slug === 'materiale' ? 'Materiale' : 'Contact'),
    href: pagePath,
  },
];
---

{slug === 'despre' && (
  <PageShell title={seoTitle} description={seoDescription} path={pagePath} breadcrumbs={breadcrumbs}>
    <section class="section section--alt">
      <div class="container container--wide about">
        <p class="section__eyebrow">Despre noi</p>
        <h1 class="section__title">{site.about.title}</h1>
        {site.about.paragraphs.map((p) => (
          <p class="about__p">{p}</p>
        ))}
      </div>
    </section>
    <HowWeWork />
    <WhyDecorao />
  </PageShell>
)}

{slug === 'materiale' && (
  <PageShell title={seoTitle} description={seoDescription} path={pagePath} breadcrumbs={breadcrumbs}>
    <section class="section section--alt">
      <div class="container container--wide">
        <p class="section__eyebrow">Materiale</p>
        <h1 class="section__title">{site.materials.title}</h1>
        <p class="about__p">{site.materials.intro}</p>
      </div>
    </section>
    <MaterialsShowcase />
  </PageShell>
)}

{slug === 'contact' && (
  <PageShell title={seoTitle} description={seoDescription} path={pagePath} breadcrumbs={breadcrumbs}>
    <ContactSection heading="h1" />
  </PageShell>
)}

{room && (
  <PageShell title={seoTitle} description={seoDescription} path={pagePath} breadcrumbs={breadcrumbs}>
    <RoomSection
      id={room.id}
      title={room.title}
      intro={room.intro}
      features={room.features}
      images={getGalerieForRoom(room.id)}
      heading="h1"
    />
  </PageShell>
)}

<style>
  .about__p {
    color: var(--color-muted);
    margin: 0 0 0.85rem;
    font-size: 1.05rem;
    line-height: 1.5;
  }
</style>
