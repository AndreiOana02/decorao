---
import PageShell from '../components/PageShell.astro';
import HeroHome from '../components/HeroHome.astro';
import StatsBar from '../components/StatsBar.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import site from '../data/site.json';
import { getGalerieByRoom, getHeroSlides } from '../lib/galerie';

const galerieByRoom = getGalerieByRoom();
const heroSlides = getHeroSlides(site.rooms.map((r) => r.id));
---

<PageShell isHome path="/">
  <HeroHome slides={heroSlides} />
  <StatsBar />
  <CategoryGrid galerieByRoom={galerieByRoom} />
  <section class="section home-cta">
    <div class="container container--wide home-cta__inner">
      <h2 class="home-cta__title">Mobilă la comandă — ai un proiect în minte?</h2>
      <p class="home-cta__text">
        Spune-ne ce cameră te interesează — bucătărie, dormitor, living sau uși. Revenim cu ofertă și termen estimat.
      </p>
      <div class="home-cta__actions">
        <a class="btn btn--primary" href="/contact">Solicită ofertă</a>
        <a class="btn btn--ghost" href="/despre">Despre Decorao</a>
      </div>
    </div>
  </section>
</PageShell>

<style>
  .home-cta {
    padding-top: 2rem;
    padding-bottom: 3rem;
  }

  .home-cta__inner {
    text-align: center;
    max-width: 36rem;
  }

  .home-cta__title {
    margin: 0 0 0.65rem;
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 3vw, 2rem);
    font-weight: 500;
  }

  .home-cta__text {
    margin: 0 0 1.25rem;
    color: var(--color-muted);
    line-height: 1.5;
  }

  .home-cta__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }
</style>
